<script>

if('scrollRestoration' in history) history.scrollRestoration='manual';

var REVIEWS=[

  {text:'一口气从CFHD买到彩虹六号再买到The Finals，三款全入手，稳。',author:'CFHD 三件套客户',highlight:true},

  {text:'彩虹六号续费，用着舒服就一直用，售后省心。',author:'彩虹六号 续费客户',highlight:true},

  {text:'CFHD瞬狙真的稳，28把枪全有宏，练枪效率翻倍。',author:'CFHD老玩家'},

  {text:'The Finals AK和FCAR压枪舒服，扫射不飘。',author:'The Finals玩家'},

  {text:'三角洲行动全套宏，血手鼠标插上即用，体验丝滑。',author:'三角洲行动玩家'},

  {text:'本地AI模型部署很省钱，生产力拉满。',author:'AI玩家'}

];

var SERVICES=[

  {code:'SERVICE 01',title:'本地模型部署',desc:'帮你把AI大模型部署到电脑上，减少按量API成本。支持DeepSeek、Qwen、Llama等主流开源模型，提供一键启动脚本和远程调优。',price:'¥500-600',note:'一次性部署'},

  {code:'SERVICE 02',title:'视频VIP集成',desc:'B站大会员、视频会员等集成服务，稳定靠谱，售后到位。',price:'¥88',note:'长期方案'},

  {code:'SERVICE 03',title:'鼠标参数修改',desc:'根据DPI、回报率、游戏灵敏度和手感偏好做深度定制。',price:'¥68',note:'深度定制'},

  {code:'SERVICE 04',title:'电脑装机服务',desc:'深圳本地上门装机，外地远程指导选配置。从预算规划到走线理线一步到位。',price:'¥2000+',note:'按配置定价'}

];

var TRADES=['彩虹六号全套','CFHD全套','The Finals全套','三角洲行动全套','生死狙击2全套','高能英雄全套','AVA全套','界外狂潮全套','和平精英模拟器全套'];

var curReview=0,reviewTimer=null;

function toggleMenu(){document.getElementById('navLinks').classList.toggle('active');}

document.querySelectorAll('#navLinks a').forEach(function(a){a.addEventListener('click',function(){document.getElementById('navLinks').classList.remove('active');});});

function initTicker(){var t=document.getElementById('tickerTrack');var html='';for(var i=0;i<16;i++){var item=TRADES[i%TRADES.length];html+='<span><b>LIVE DEPLOY</b> '+item+' / 参数更新完成</span>';}t.innerHTML=html+html;}

function initReviews(){var track=document.getElementById('reviewTrack');var dots=document.getElementById('reviewDots');REVIEWS.forEach(function(r,i){var card=document.createElement('article');card.className='review-card'+(r.highlight?' highlight':'');card.innerHTML='<p class="review-text">“'+r.text+'”</p><div class="review-author">'+r.author+'</div>';track.appendChild(card);var dot=document.createElement('button');dot.className='dot'+(i===0?' active':'');dot.setAttribute('aria-label','切换评价 '+(i+1));dot.onclick=function(){goReview(i);};dots.appendChild(dot);});startReviewAuto();}

function goReview(i){curReview=i;document.getElementById('reviewTrack').style.transform='translateX(-'+(i*100)+'%)';document.querySelectorAll('.dot').forEach(function(d,j){d.className='dot'+(j===i?' active':'');});}

function nextReview(){goReview((curReview+1)%REVIEWS.length);}function prevReview(){goReview((curReview-1+REVIEWS.length)%REVIEWS.length);}function startReviewAuto(){reviewTimer=setInterval(nextReview,5200);}function stopReviewAuto(){clearInterval(reviewTimer);}var reviews=document.querySelector('.reviews');if(reviews){reviews.addEventListener('mouseenter',stopReviewAuto);reviews.addEventListener('mouseleave',startReviewAuto);}

function toggleFaq(btn){btn.parentElement.classList.toggle('active');}

function openModal(bvid){var mc=document.querySelector('.modal-content');mc.style.animation='none';void mc.offsetWidth;mc.style.animation='';document.getElementById('modalIframe').src='https://player.bilibili.com/player.html?bvid='+bvid+'&autoplay=0';document.getElementById('videoModal').classList.add('active');document.body.style.overflow='hidden';}

function closeModal(){var mc=document.querySelector('.modal-content');mc.classList.add('closing');setTimeout(function(){document.getElementById('modalIframe').src='';document.getElementById('videoModal').classList.remove('active');mc.classList.remove('closing');mc.style.animation='none';void mc.offsetWidth;mc.style.animation='';document.body.style.overflow='';},180);}

function openService(i){var s=SERVICES[i];var card=document.querySelector('.service-modal-card');card.style.animation='none';void card.offsetWidth;document.getElementById('serviceDetailBody').innerHTML='<div class="eyebrow">'+s.code+'</div><h3>'+s.title+'</h3><p>'+s.desc+'</p><div class="service-price">'+s.price+' <span>'+s.note+'</span></div><a class="btn btn-primary" href="#contact" onclick="closeService()">立即咨询 <i class="arrow"></i></a>';card.style.animation='';document.getElementById('serviceModal').classList.add('active');document.body.style.overflow='hidden';}

function closeService(){var card=document.querySelector('.service-modal-card');card.classList.add('closing');setTimeout(function(){document.getElementById('serviceModal').classList.remove('active');card.classList.remove('closing');card.style.animation='none';void card.offsetWidth;card.style.animation='';document.body.style.overflow='';},280);}

var backTop=document.getElementById('backTop');window.addEventListener('scroll',function(){if(window.scrollY>560)backTop.classList.add('visible');else backTop.classList.remove('visible');});

var observer=new IntersectionObserver(function(entries){entries.forEach(function(e){if(e.isIntersecting)e.target.classList.add('visible');});},{threshold:.12});document.querySelectorAll('.fade,.fade-left,.fade-right,.fade-scale').forEach(function(el){observer.observe(el);});

(function(){initTicker();initReviews();var fp=document.getElementById('fake_pv');if(fp){var bv=document.getElementById('busuanzi_value_site_pv');if(bv&&bv.textContent.trim()){fp.textContent=bv.textContent.trim();}else{var h=new Date().getHours();var total=1000000+Math.floor(Math.random()*99999)+h*10000;fp.textContent=total;}}})();

window.addEventListener('load',function(){setTimeout(function(){window.scrollTo(0,0);},50);});

(function(){if(window.innerWidth>768){var h=document.querySelector('.hero');if(h){var m=h.querySelector('.hero-media');h.addEventListener('mousemove',function(e){var x=(e.clientX/window.innerWidth-.5)*24;var y=(e.clientY/window.innerHeight-.5)*12;m.style.transform='translate('+x+'px,'+y+'px)';});h.addEventListener('mouseleave',function(){m.style.transform='';});}}
document.querySelectorAll('.game-card,.service-card,.video-card').forEach(function(c){c.addEventListener('mousemove',function(e){if(window.innerWidth<=768)return;var r=this.getBoundingClientRect();var x=(e.clientX-r.left)/r.width-.5;var y=(e.clientY-r.top)/r.height-.5;this.style.transform='perspective(800px) rotateY('+(x*8)+'deg) rotateX('+(-y*8)+'deg) translateY(-4px)';});c.addEventListener('mouseleave',function(){this.style.transform='';});});})();

</script>

</body>

</html>