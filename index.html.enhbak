<script>
        // 微信浏览器强制置顶（微信会自动恢复滚动位置，必须多重兜底）
        if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
        !function() {
            // UA检测：微信显示图片，非微信显示视频
            document.addEventListener('DOMContentLoaded', function() {
                var isWeChat = /MicroMessenger/i.test(navigator.userAgent);
                var img = document.querySelector('.hero-bg-img');
                var vids = document.querySelectorAll('.hero-bg-video');
                if (isWeChat) {
                    if (img) img.style.display = 'block';
                    vids.forEach(function(v){ v.style.display = 'none'; });
                } else {
                    if (img) img.style.display = 'none';
                    vids.forEach(function(v){ 
                        v.style.display = ''; 
                        v.play().catch(function(){});
                    });
                }
            });
            var t = function() { window.scrollTo(0, 0); };
            t();
            document.addEventListener('DOMContentLoaded', t);
            window.addEventListener('load', t);
            // 微信浏览器特有：从缓存恢复页面时（pageshow事件）
            window.addEventListener('pageshow', function(e) {
                if (e.persisted) { t(); }
                t();
            });
            setTimeout(t, 100);
            setTimeout(t, 500);
            setTimeout(t, 1000);
            var check = function() {
                if (window.scrollY > 0) { window.scrollTo(0, 0); requestAnimationFrame(check); }
            };
            requestAnimationFrame(check);
        }();
    </script>

